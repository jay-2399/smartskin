# Base de données — prod : Postgres (Render EU). Dev local : SQLite (`file:./prisma/dev.db`).
# Le provider Prisma + l'adapter (src/lib/db.ts) sont choisis selon le préfixe de l'URL.
# En dev : `npm run db:push` (crée/synchronise la base SQLite + régénère le client).
DATABASE_URL="postgresql://user:password@host:5432/smartskin"

# Auth.js
AUTH_SECRET="genere-avec: openssl rand -base64 32"

# Google OAuth (connexion un clic).
# URL de redirection autorisée à déclarer dans la console Google :
#   dev  → http://localhost:3000/api/auth/callback/google
#   prod → https://app.smart-skin.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (liens magiques par email). EMAIL_FROM : pour tester sans domaine vérifié,
# utiliser "onboarding@resend.dev" (n'envoie qu'à TA propre adresse Resend) ; en prod,
# une adresse de ton domaine vérifié, ex. "SmartSkin <noreply@smart-skin.ai>".
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# Stripe (paiement « accès à vie », 19,99 $). Mode TEST d'abord (clés sk_test_…).
# STRIPE_SECRET_KEY : Dashboard Stripe → Développeurs → Clés API → clé secrète.
# STRIPE_WEBHOOK_SECRET : fourni par `stripe listen` (test local) ou le webhook du Dashboard (prod).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Stockage des photos de scan (Supabase Storage, bucket privé `scan-photos`) ──
# SUPABASE_URL : Supabase → Project Settings → API → Project URL.
# SUPABASE_SERVICE_ROLE_KEY : même page → clé `service_role` (SECRÈTE, serveur seulement).
# Vides → l'upload est ignoré (pas de crash) et l'avatar retombe sur l'initiale.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Analyse photo (un seul fournisseur suffit) ──
# Priorité : Anthropic > OpenAI > Gemini > démo. Si aucune clé → bilan d'exemple (mode démo).

# Anthropic (analyse photo = Claude Opus 4.8 vision ; routine « pourquoi » = Sonnet 4.6).
# Le plus rigoureux pour suivre les consignes anti-hallucination. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# OpenAI (modèle gpt-5.5, vision). https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Gemini (alternative) — clé Google AI Studio. https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Production UE (RGPD) : bascule Gemini → Vertex AI europe-west (cf. gemini.ts),
# ou OpenAI → Azure OpenAI région EU.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="europe-west1"
GOOGLE_APPLICATION_CREDENTIALS="./gcloud-key.json"

# ── Recommandation produit (affiliation Amazon) ──
# Tag d'affiliation Amazon ajouté aux liens produits (?tag=). Optionnel : repli sur
# une valeur par défaut si absent. https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG="smartskin-20"

# ── Analytics ──
# Microsoft Clarity (heatmaps + session replays). ID PUBLIC (Clarity → Settings →
# Overview). Préfixe NEXT_PUBLIC_ = exposé au navigateur (normal). Vide → Clarity inactif.
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# PostHog (analytics + feature flags + A/B Experiments). Clé projet PUBLIQUE (phc_…),
# PostHog → Settings → Project. Host EU (RGPD) par défaut. Vide → PostHog inactif.
# L'A/B paywall utilise un feature flag/experiment nommé "different-paywall-page"
# (control → paywall A clair ; toute autre variante → paywall B sombre).
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ── Code-gate viral (reveal) ──
# Code de campagne épinglé sous la vidéo TikTok ; seul ce code débloque l'écran reveal.
# Validé côté serveur (jamais exposé au navigateur). Vide/absent → gate ouvert (dev).
REVEAL_GATE_CODE="GLOW5"
